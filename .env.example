# Shared secret used by go-api to sign payloads forwarded to kotlin-core (HMAC-SHA256 hex).
# Must match in both services.
SPONSOR_HMAC_SECRET=dev-secret-change-in-prod

# Base URL kotlin-core uses internally (overridden in docker-compose for go-api to service DNS).
KOTLIN_CORE_URL=http://kotlin-core:8081

# Simulated AKN liquidity pool starting balance (minor units).
AKN_POOL_INITIAL=10000000

# Simulated PAW liquidity pool starting balance (minor units).
PAW_POOL_INITIAL=500000

# Probability [0,1] that AkinNet fails before kotlin-core is contacted (go-api returns HTTP 422).
AKINNET_FAILURE_RATE=0

# When > 0, kotlin-core may return DELAYED for certain demo amounts (see README); models sponsor queue latency.
SPONSOR_DELAY_SECONDS=60

# Probability [0,1] that kotlin-core simulates a Corda/Cordapp failure (HTTP 502 from core).
CORDAPP_FAILURE_RATE=0
